---
interface Props {
  title?: string;        // für og:title mapping
  pathname?: string;     // fallback für pathname mapping
}

const { title, pathname = Astro.url.pathname } = Astro.props;
---

{
  /* nur rendern wenn wir auf einem blog-post sind – du entscheidest wie */
  title && (
    <section class="mt-16 pt-10 border-t border-zinc-200 dark:border-zinc-800">
      <h2 class="text-2xl font-medium mb-6 flex items-center gap-2">
        💬 kommentare & diskussion
      </h2>
      
      <div id="giscus"></div>

      <script is:inline define:vars={{ title, pathname }}>
        const script = document.createElement('script');
        script.src = 'https://giscus.app/client.js';
        
        script.setAttribute('data-repo', 'DEINUSERNAME/miplos');           // ← dein repo (oder separates comments-repo)
        script.setAttribute('data-repo-id', 'R_kgDO...');                 // ← aus giscus.app
        script.setAttribute('data-category', 'Announcements');            // oder "General"
        script.setAttribute('data-category-id', 'DIC_kwDO...');           // ← aus giscus.app
        script.setAttribute('data-mapping', 'og:title');                  // empfohlen für blog (stabil)
        // alternativ: 'pathname' wenn du urls nie änderst
        script.setAttribute('data-strict', '0');
        script.setAttribute('data-reactions-enabled', '1');
        script.setAttribute('data-emit-metadata', '0');
        script.setAttribute('data-input-position', 'bottom');
        script.setAttribute('data-theme', 'preferred_color_scheme');
        script.setAttribute('data-lang', 'de');
        script.setAttribute('data-loading', 'lazy');
        script.setAttribute('crossorigin', 'anonymous');
        script.async = true;

        document.getElementById('giscus').appendChild(script);
      </script>
    </section>
  )
}
---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

  <style>
    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .hero {
      text-align: center;
      padding: 6rem 2rem 5rem;
      background: linear-gradient(135deg, #0f172a 0%, #1e2937 100%);
      color: white;
      border-radius: 20px;
      margin-bottom: 3rem;
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.3);
    }

    .hero h1 {
      font-size: 4.5rem;
      font-weight: 800;
      margin: 0 0 1rem;
      letter-spacing: -0.05em;
      color: #ffffff;
      text-shadow: 0 4px 25px rgba(0, 0, 0, 0.6);
    }

    .hero .tagline {
      font-size: 1.7rem;
      margin: 0 0 2rem;
      opacity: 0.95;
      font-weight: 500;
      letter-spacing: 0.02em;
    }

    .hero .subtitle {
      max-width: 740px;
      margin: 0 auto 3rem;
      font-size: 1.28rem;
      opacity: 0.93;
      line-height: 1.55;
    }

    .explore-btn {
      display: inline-block;
      padding: 16px 42px;
      background: white;
      color: #0f172a;
      font-weight: 600;
      border-radius: 9999px;
      text-decoration: none;
      font-size: 1.08rem;
      transition: all 0.25s ease;
    }

    .explore-btn:hover {
      background: #24fb97;
      color: #0f172a;
      transform: translateY(-3px);
    }

    .section-title {
      font-size: 1.85rem;
      margin: 3rem 0 1.5rem;
      font-weight: 600;
    }

    ul {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 2rem;
      list-style: none;
      padding: 0;
      margin: 0;
    }

    ul li {
      background: white;
      border: 1px solid #e5e5e5;
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.25s ease;
    }

    ul li:hover {
      border-color: #24fb97;
      box-shadow: 0 15px 25px -5px rgb(0 0 0 / 0.08);
    }

    ul li img {
      width: 100%;
      height: 210px;
      object-fit: cover;
    }

    .post-content {
      padding: 1.5rem;
    }

    /* CLEAN POST LINKS - BLACK TITLE + YOUR GREEN-CYAN HOVER */
    .post-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .title {
      margin: 0 0 0.6rem;
      font-size: 1.4rem;
      line-height: 1.3;
      color: #18181b;           /* stays black */
      transition: color 0.2s ease;
    }

    .post-link:hover .title {
      color: #24fb97;           /* your desired green-cyan on hover only */
    }

    .date {
      margin: 0;
      color: #71717a;
      font-size: 0.95rem;
    }

    .hashtags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin: 3rem 0 2rem;
      justify-content: center;
    }

    .hashtag {
      background: #f4f4f5;
      color: #3f3f46;
      padding: 8px 16px;
      border-radius: 9999px;
      font-size: 0.95rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.2s;
    }

    .hashtag:hover {
      background: #24fb97;
      color: black;
    }

    @media (max-width: 720px) {
      .hero h1 { font-size: 3.2rem; }
      .hero { padding: 4.5rem 1.5rem 4rem; }
      ul { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <!-- HERO -->
    <div class="hero">
      <h1>miplos</h1>
      <p class="tagline">#Robotics #Hardware #Automation #Security #IoT</p>
      <p class="subtitle">
        real builds. battle-tested guides.<br>
        powering #Robotics with #LiFePO4 • securing networks • efficient #Homelabs & more.
      </p>
      <a href="#latest" class="explore-btn">explore the latest builds →</a>
    </div>

    <!-- LATEST POSTS -->
    <section id="latest">
      <h2 class="section-title">Latest from the Bench</h2>

      <ul>
        {
          posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="post-link">
                {post.data.heroImage && (
                  <Image
                    width={720}
                    height={360}
                    src={post.data.heroImage}
                    alt={post.data.title}
                  />
                )}
                <div class="post-content">
                  <h4 class="title">{post.data.title}</h4>
                  <p class="date">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- HASHTAGS -->
    <div class="hashtags">
      <a href="#" class="hashtag">#Robotics</a>
      <a href="#" class="hashtag">#Hardware</a>
      <a href="#" class="hashtag">#Automation</a>
      <a href="#" class="hashtag">#Security</a>
      <a href="#" class="hashtag">#IoT</a>
      <a href="#" class="hashtag">#Prototyping</a>
      <a href="#" class="hashtag">#LiFePO4</a>
      <a href="#" class="hashtag">#Proxmox</a>
      <a href="#" class="hashtag">#ESP32</a>
      <a href="#" class="hashtag">#RaspberryPi</a>
      <a href="#" class="hashtag">#3DPrinting</a>
      <a href="#" class="hashtag">#Homelab</a>
    </div>

    <!-- SHORT ABOUT -->
    <div style="text-align: center; margin: 3rem auto; color: #52525b; max-width: 720px; font-size: 1.1rem;">
      miplos is my living lab notebook turned public.
      practical #Robotics, #Hardware, #Security and #Automation projects —
      everything tested on the bench and ready to build.
    </div>
  </main>
  <Footer />
</body>
</html>
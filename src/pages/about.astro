---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  
  <style>
    main {
      max-width: 720px;
      margin: 0 auto;
      padding: 4rem 1rem;
      line-height: 1.75;
      color: #374151;
    }
    h1 {
      font-size: 2.8rem;
      margin-bottom: 1.8rem;
      color: #111827;
    }
    .content p {
      margin-bottom: 1.6rem;
      font-size: 1.15rem;
    }
  </style>
</head>
<body>
  <Header />

  <main>
    <h1>about miplos</h1>
    
    <div class="content">
      <p>
        Hi, I’m Radojica. 
        Together with my two kids I run miplos as our shared lab notebook.
      </p>
      <p>
        We build real stuff: robots, hardware projects, 
        secure homelabs, automation systems and IoT experiments.
      </p>
      <p>
        Everything here is tested on the bench and documented step-by-step 
        so others can build it too. Practical projects only — no fluff.
      </p>
    </div>
  </main>

  <Footer />
</body>
</html>